# Discord 봇 토큰입니다.
# Discord Developer Portal > Applications > 내 앱 > Bot > Token에서 복사하세요.
# 실제 토큰은 절대 공유하지 마세요.
DISCORD_TOKEN=your-discord-bot-token

# Discord 애플리케이션 ID입니다.
# Discord Developer Portal > Applications > 내 앱 > General Information > Application ID
CLIENT_ID=123456789012345678

# 봇을 사용할 Discord 서버 ID입니다.
# Discord 개발자 모드를 켠 뒤 서버를 우클릭해서 ID를 복사하세요.
GUILD_ID=123456789012345678

# 민원 채널이 생성될 카테고리 ID입니다.
# 대상 카테고리를 우클릭해서 ID를 복사하세요.
COMPLAINT_CATEGORY_ID=123456789012345678

# 종료된 민원 기록 파일이 올라갈 채널 ID입니다.
# 봇에게 메시지 전송과 파일 첨부 권한이 있어야 합니다.
LOG_CHANNEL_ID=123456789012345678

# 새 민원 또는 긴급 알림이 올라갈 채널 ID입니다.
ALERT_CHANNEL_ID=123456789012345678

# 민원을 처리할 관리자 역할 ID입니다.
# 서버 설정의 역할 목록에서 해당 역할 ID를 복사하세요.
ADMIN_ROLE_ID=123456789012345678

# 최고관리자 사용자 ID입니다.
# 민감한 관리자 전용 기능을 사용할 수 있는 계정입니다.
SUPER_ADMIN_ID=123456789012345678


# 민원 세션 자동 종료 기준 시간입니다.
# 단위는 시간입니다.
SESSION_TIMEOUT_HOURS=24

# 같은 사용자가 다시 민원을 넣기 전까지 기다려야 하는 시간입니다.
# 단위는 분입니다.
COOLDOWN_MINUTES=30

# 암호화된 종료 기록을 복호화할 수 있는 보관 기간입니다.
# 단위는 일이며, 기간이 지나면 CLI/GUI에서 .enc 파일 복호화를 막습니다.
RECORD_RETENTION_DAYS=180


# 운영시간 설정입니다.
# 24시간 형식이며, 아래 기본값은 Asia/Seoul 기준 09:00~18:00입니다.
WORK_HOURS_START=9
WORK_HOURS_END=18
WORK_HOURS_TIMEZONE=Asia/Seoul

# true: 운영시간 밖에도 민원을 접수하고 안내문을 보여줍니다.
# false: 운영시간 밖에는 민원 접수를 막습니다.
ACCEPT_COMPLAINTS_OUTSIDE_WORK_HOURS=true

# true: 사용자에게 운영시간 안내문을 보여줍니다.
# false: 운영시간 안내문을 보여주지 않습니다.
ENABLE_WORK_HOURS_NOTICE=true


# 종료 민원 기록을 암호화할 때 사용할 RSA 공개키 경로입니다.
# 봇 서버에는 public.pem만 두고, private.pem은 최고관리자 개인 PC에만 보관하세요.
PUBLIC_KEY_PATH=./keys/public.pem

# 선택 사항: Redis 연결 주소입니다.
# 비워두면 ./sessions/*.enc.json 파일에 암호화된 세션 상태를 저장합니다.
# 예시: redis://localhost:6379
REDIS_URL=

# 세션/차단/쿨다운 상태를 암호화할 32바이트 base64 키입니다.
# 생성 명령: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# 이 값은 반드시 비밀로 보관하세요. 바꾸면 기존 세션 파일을 읽을 수 없습니다.
SESSION_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key


# 사용자가 첨부할 수 있는 파일 최대 크기입니다.
# 단위는 MB입니다.
MAX_ATTACHMENT_SIZE_MB=10

# true: 공개 .txt 기록에도 관리자 내부 메모를 포함합니다.
# false: 내부 메모는 암호화된 .enc 기록에만 포함합니다.
INCLUDE_INTERNAL_MEMOS_IN_TXT=false
